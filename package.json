{
  "name": "mdsite-cli",
  "version": "1.0.0",
  "description": "Markdown文档静态站点生成器命令行工具",
  "bin": {
    "mdsite": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "prepublishOnly": "npm run build"
  },
